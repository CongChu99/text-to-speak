# ─── Translation Provider ───
# Options: 'ollama' (free, local) or 'openai' (paid)
TRANSLATION_PROVIDER=ollama

# Ollama settings (free, local) — run: ollama pull gemma3:4b
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# OpenAI API key (only needed if TRANSLATION_PROVIDER=openai)
# OPENAI_API_KEY=your_openai_api_key_here

# ─── Optional: API Mode (not needed for free mode) ───
# Deepgram API key for server-side STT (free mode uses browser STT instead)
# DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Google Cloud credentials for server-side TTS (free mode uses browser TTS instead)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ─── Server Configuration ───
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
VITE_BACKEND_URL=http://localhost:3001
